{
  "name": "sonal",
  "version": "0.0.1",
  "author": "Alex Alber - Université de Tours",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-icons": "electron-icon-builder --input=./icon/icon.png --output=./dist"
  },
  "build": {
    "appId": "com.sonal.id",
    "productName": "Sonal",
    "npmRebuild": false,
    "asar": true,
    "mac": {
      "icon": "icon/icon.png"
    },
    "linux": {
      "icon": "icon/icon.png",
      "target": ["AppImage", "deb"]
    },
    "files": [
      "main.js",
      "package.json",
      "preload.js",
      "renderer.js",
      "index.html",
      "ajout-entretien.html",
      "edition_categories.html",
      "edition_entretien.html",
      "nouveau_corpus.html",
      "modules/**/*",
      "dist/**/*",
      "css/**/*",
      "node_modules/**/*",
      "img/**/*",
      "icon/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/iconv-lite/**/*",
      "**/node_modules/chardet/**/*",
      "**/node_modules/safer-buffer/**/*",
      "**/node_modules/encoding/**/*",
      "**/node_modules/node-fetch/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "icon/icon.png"
    }
  },
  "dependencies": {
    "chardet": "^2.1.0",
    "electron-store": "^7.0.3",
    "iconv-lite": "^0.6.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "38.1.2",
    "electron-builder": "^26.0.12",
    "electron-icon-builder": "^2.0.1"
  }
}
