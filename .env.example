# ─────────────────────────────────────────────────────────────────────────────
# Modèle de configuration des tests Playwright — SonalPi
# Copier ce fichier en ".env" et remplir les valeurs.
# Le fichier ".env" est ignoré par Git (credentials), ".env.example" est commité.
# ─────────────────────────────────────────────────────────────────────────────

GITLAB_INSTANCE=http://localhost
GITLAB_PROJECT=namespace/nom-du-projet
GITLAB_BRANCH=main

# Authentification : fournir soit un token direct (recommandé), soit username+password
# Si GITLAB_TOKEN_USERx est renseigné, le browser automation OAuth est ignoré.
# CLIENT_ID et CLIENT_SECRET correspondent à l'application OAuth GitLab de chaque utilisateur.
GITLAB_CLIENT_ID_USER1=
GITLAB_CLIENT_SECRET_USER1=
GITLAB_USERNAME_USER1=
GITLAB_TOKEN_USER1=
GITLAB_PASSWORD_USER1=

GITLAB_CLIENT_ID_USER2=
GITLAB_CLIENT_SECRET_USER2=
GITLAB_USERNAME_USER2=
GITLAB_TOKEN_USER2=
GITLAB_PASSWORD_USER2=

GITLAB_CRP=corpus-test.crp
GITLAB_ENTRETIEN1=entretien1.sonal
GITLAB_ENTRETIEN2=entretien2.sonal

PLAYWRIGHT_HEADLESS=true
